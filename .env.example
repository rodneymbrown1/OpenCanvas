# ─────────────────────────────────────────────────────────────────────────────
# Open Canvas — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and customize as needed.
# All variables have sensible defaults — the app runs without any .env file.
#
# These can also be configured via Settings → Open Canvas in the UI,
# which persists values to ~/.open-canvas/global.yaml and takes precedence
# over environment variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Debugging ────────────────────────────────────────────────────────────────

# Enable verbose logging (colored, categorized console output).
# Also toggleable via Settings → Open Canvas, or browser console:
#   window.__ocLogger.enable()
VITE_VERBOSE_LOG=false

# Enable poll/performance debug logging (independent of verbose logging).
# Logs every poll cycle: timing, skips, backoff delays, and tab-resume events
# for the jobs, stack, services, ports, file-tree, and terminal-retry loops.
# Also toggleable via Settings → Open Canvas, or browser console:
#   window.__ocLogger.enablePollDebug()
VITE_POLL_DEBUG=false

# ── Server ───────────────────────────────────────────────────────────────────

# Port for the Next.js dev server (standard Next.js variable)
PORT=3000

# Port for the PTY websocket server
PTY_PORT=3001

# ── Paths ────────────────────────────────────────────────────────────────────

# Override the Open Canvas home directory (default: ~/.open-canvas)
# Stores global config, shared data, calendar, and project registry.
# OC_HOME=~/.open-canvas

# ── Shell ────────────────────────────────────────────────────────────────────

# Shell used for PTY terminal sessions (default: $SHELL or /bin/zsh)
# SHELL=/bin/zsh
